[Unit]
Description=FastDOL API
After=network.target postgresql.service pgbouncer.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/employer-compliance
EnvironmentFile=/opt/employer-compliance/.env.api
ExecStart=/opt/employer-compliance/venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8001 --workers 4
Restart=always
RestartSec=5

# Hardening
ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes
PrivateTmp=yes
ReadWritePaths=/opt/employer-compliance

[Install]
WantedBy=multi-user.target
